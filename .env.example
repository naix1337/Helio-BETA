# Pulse — Environment Configuration

# Server
PORT=3001
HOST=0.0.0.0

# Database (SQLite)
DB_PATH=./pulse.db

# Authentication
JWT_SECRET=generate-a-random-64-char-string-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=*

# Data Retention
RETENTION_RAW_DAYS=7

# Notifications
NTFY_DEFAULT_SERVER=https://ntfy.sh
